{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/docs",
  "targets": {
    "serve": {
      "dependsOn": ["examples:buildElements"],
      "executor": "nx:run-commands",
      "options": {
        "commands": ["npx nx run examples:buildElements --watch", "vitepress dev apps/docs"],
        "parallel": true
      }
    }
  }
}
